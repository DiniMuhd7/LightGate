{
  "expo": {
    "name": "LifeGate",
    "slug": "lifegate",
    "version": "1.0.13",
    "orientation": "portrait",
    "icon": "./icons/icon-512.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./icons/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B5E52"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.dshub.lifegate",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LifeGate needs microphone access for websites that use voice input.",
        "NSCameraUsageDescription": "LifeGate needs camera access for websites that use the camera.",
        "NSLocationWhenInUseUsageDescription": "LifeGate needs location access for websites that use your location.",
        "NSSpeechRecognitionUsageDescription": "LifeGate uses speech recognition so you can speak to websites that support voice input."
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.associated-domains": [
          "webcredentials:mobile.dshub.com.ng",
          "webcredentials:lifegate.dshub.com.ng"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icons/icon-512.png",
        "backgroundColor": "#0B5E52"
      },
      "package": "com.dshub.lifegate",
      "navigationBarColor": "#0AADA2",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 13
    },
    "web": {
      "favicon": "./icons/icon-192.png"
    },
    "plugins": [
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./icons/icon-192.png",
          "color": "#0AADA2",
          "defaultChannel": "default",
          "androidMode": "default",
          "androidCollapsedTitle": "LifeGate"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableJetifier": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7876cd83-43ce-48f6-b7de-4ba5c85cce9a"
      },
      "androidSigning": {
        "appSigningKeyCertificateSha1": "9D:DE:13:B8:4A:8C:94:96:12:B0:00:E2:94:00:57:D7:98:0D:34:46",
        "uploadKeyCertificateSha1": "06:C3:63:B2:B6:43:F7:2F:69:35:F4:DF:3F:48:FC:7B:41:2B:36:2C"
      }
    },
    "owner": "muhdsdeen7"
  }
}
